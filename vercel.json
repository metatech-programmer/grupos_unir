{
  "name": "Grupos - Organizador de Equipos",
  "version": "0.1.0",
  "description": "Plataforma inteligente para organizar grupos de trabajo considerando zonas horarias",
  "deployButton": {
    "template": "nextjs",
    "url": "https://vercel.com/new/clone?repository-url=https%3A%2F%2Fgithub.com%2Ftu-usuario%2Fgrupos&env=NEXT_PUBLIC_SUPABASE_URL,NEXT_PUBLIC_SUPABASE_ANON_KEY"
  },
  "env": [
    {
      "key": "NEXT_PUBLIC_SUPABASE_URL",
      "description": "Tu URL de Supabase",
      "link": "https://supabase.com",
      "required": true
    },
    {
      "key": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
      "description": "Tu clave anónima de Supabase",
      "link": "https://supabase.com",
      "required": true
    }
  ]
}
